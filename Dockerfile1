FROM eclipse-temurin:21-jdk-alpine

# Update and patch all vulnerabilities
COPY filtered_summary.txt /tmp/

# Update and patch all vulnerabilities
RUN awk '!/^$/ && !seen[$1]++ {print}' /tmp/filtered_summary.txt | \
    xargs -r sh -c 'for pkg; do apk add --no-cache "$pkg" || echo "Skipped $pkg"; done' _

WORKDIR /app

# Copy pre-built JAR
COPY news-feed/target/*.jar app.jar

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]



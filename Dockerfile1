FROM eclipse-temurin:21-jdk-alpine

# Update and patch all vulnerabilities
RUN apk update && apk upgrade && \
    apk add --no-cache \
      gnutls=3.8.12-r0 \
      libpng=1.6.56-r0 \
      zlib=1.3.2-r0

WORKDIR /app

# Copy pre-built JAR
COPY news-feed/target/*.jar app.jar

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]